# ── IBM watsonx credentials (required) ────────────────────────────────────────
# IBM Cloud API key — https://cloud.ibm.com → Manage → Access (IAM) → API keys
WATSONX_API_KEY=your-ibm-cloud-api-key

# watsonx.ai project ID — watsonx.ai → project → Manage → General → Project ID
WATSONX_PROJECT_ID=your-watsonx-project-id

# watsonx.ai endpoint (default: Dallas; change region if needed)
# Options: https://us-south.ml.cloud.ibm.com  https://eu-de.ml.cloud.ibm.com
#          https://eu-gb.ml.cloud.ibm.com      https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ── TechZone MCP integration (optional) ───────────────────────────────────────
# TechZone API key — https://techzone.ibm.com → your profile → API keys
# When set, the "Request TechZone environment" button makes a live MCP API call.
# When absent, the button is shown but disabled with an info message.
TECHZONE_API_KEY=your-techzone-api-key

# TechZone MCP endpoint — only override if you use a different server instance
TECHZONE_MCP_URL=https://mcp.techzone.ibm.com/servers/c7442b81221647c3b36c75df4f2f88e8/mcp

# ── Bob Shell (only needed when running the agentic build loop) ───────────────
# Get from https://bob.ibm.com/admin/apikeys
BOBSHELL_API_KEY=your-bob-shell-api-key
